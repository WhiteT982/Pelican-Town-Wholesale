{
  "Format": "2.9.1",
  "ConfigSchema": {
    "Board Appearance and Location": {
      "AllowValues": "Order Board, Order Stand, Seven Deadly Sins Compatibility",
      "Default": "Order Board",
      "Section": "Appearance and Map Compatibility"
    }
  },
  "Changes": [
    {
      "Action": "Include",
      "FromFile": "Data/specialorders.json, Data/contexttags.json, Data/quests.json, Data/triggers.json"
    },
    {
      "When": {
        "HasMod": "Adam.Joja_Machines"
      },
      "Action": "Include",
      "FromFile": "Data/jojamachines.json"
    },
    {
      "When": {
        "HasMod": "FlashShifter.StardewValleyExpandedCP"
      },
      "Action": "Include",
      "FromFile": "Data/SVE.json"
    },
    {
      "LogName": "Change to Board",
      "Action": "Include",
      "FromFile": "Data/mappatchesboard.json",
      "When": {
        "Board Appearance and Location": "Order Board"
      }
    },
    {
      "LogName": "Change to Stand",
      "Action": "Include",
      "FromFile": "Data/mappatchesstand.json",
      "When": {
        "Board Appearance and Location": "Order Stand"
      }
    },
    {
      "LogName": "Change to SDS",
      "Action": "Include",
      "FromFile": "Data/mappatchesSDS.json",
      "When": {
        "Board Appearance and Location": "Seven Deadly Sins Compatibility"
      }
    }
]
}